@prefix : <http://iff.edu.br/saeg/sopontology/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sop: <http://iff.edu.br/saeg/sopontology#> .
@prefix wot: <http://xmlns.com/wot/0.1/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix terms: <http://purl.org/dc/terms/> .
@base <http://iff.edu.br/saeg/sopontology/> .

<http://iff.edu.br/saeg/sopontology> rdf:type owl:Ontology ;
                                      owl:imports org: ,
                                                  foaf: .

#################################################################
#    Object Properties
#################################################################

###  http://iff.edu.br/saeg/sopontology#approvedBy
sop:approvedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain sop:Sop ;
               rdfs:range foaf:Agent .


###  http://iff.edu.br/saeg/sopontology#checkedBy
sop:checkedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain sop:Sop ;
              rdfs:range foaf:Agent .


###  http://iff.edu.br/saeg/sopontology#classification
sop:classification rdf:type owl:ObjectProperty ;
                   rdfs:domain sop:Sop ;
                   rdfs:range skos:Concept .


###  http://iff.edu.br/saeg/sopontology#createdBy
sop:createdBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain sop:Sop ;
              rdfs:range foaf:Agent .


###  http://iff.edu.br/saeg/sopontology#guardCondition
sop:guardCondition rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdf:type owl:FunctionalProperty ;
                   rdfs:domain sop:Transition ;
                   rdfs:range sop:BooleanExpression .


###  http://iff.edu.br/saeg/sopontology#includes
sop:includes rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain sop:Sop ;
             rdfs:range sop:Sop .


###  http://iff.edu.br/saeg/sopontology#performedAt
sop:performedAt rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain sop:Activity ;
                rdfs:range sop:Place .


###  http://iff.edu.br/saeg/sopontology#performedBy
sop:performedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain sop:Activity ;
                rdfs:range sop:Performer .


###  http://iff.edu.br/saeg/sopontology#posCondition
sop:posCondition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain sop:Activity ;
                 rdfs:range sop:BooleanExpression .


###  http://iff.edu.br/saeg/sopontology#preCondition
sop:preCondition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain sop:Activity ;
                 rdfs:range sop:BooleanExpression .


###  http://iff.edu.br/saeg/sopontology#previousVersion
sop:previousVersion rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain sop:Sop ;
                    rdfs:range sop:Sop .


###  http://iff.edu.br/saeg/sopontology#responsible
sop:responsible rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain sop:Sop ;
                rdfs:range org:Organization .


###  http://iff.edu.br/saeg/sopontology#sopItem
sop:sopItem rdf:type owl:ObjectProperty ;
            rdfs:domain sop:Sop ;
            rdfs:range sop:SopItem .


###  http://iff.edu.br/saeg/sopontology#status
sop:status rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain sop:Sop ;
           rdfs:range sop:SopStatus .


###  http://iff.edu.br/saeg/sopontology#target
sop:target rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain sop:Transition ;
           rdfs:range sop:Step .


###  http://iff.edu.br/saeg/sopontology#term
sop:term rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain sop:Sop ;
         rdfs:range skos:Concept .


###  http://iff.edu.br/saeg/sopontology#transition
sop:transition rdf:type owl:ObjectProperty ;
               rdfs:domain sop:Step ;
               rdfs:range sop:Transition .


###  http://www.w3.org/ns/org#classification
org:classification rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain sop:Sop .


###  http://xmlns.com/foaf/0.1/fundedBy
foaf:fundedBy rdfs:subPropertyOf foaf:focus .


#################################################################
#    Data properties
#################################################################

###  http://iff.edu.br/saeg/sopontology#approvalDate
sop:approvalDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain sop:Sop ;
                 rdfs:range xsd:date .


###  http://iff.edu.br/saeg/sopontology#audio
sop:audio rdf:type owl:DatatypeProperty ;
          rdfs:domain sop:Entity ;
          rdfs:range xsd:string .


###  http://iff.edu.br/saeg/sopontology#creationDate
sop:creationDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain sop:Sop ;
                 rdfs:range xsd:dateTime .


###  http://iff.edu.br/saeg/sopontology#description
sop:description rdf:type owl:DatatypeProperty ;
                rdfs:domain sop:Entity ;
                rdfs:range xsd:string .


###  http://iff.edu.br/saeg/sopontology#discriminator
sop:discriminator rdf:type owl:DatatypeProperty ;
                  rdfs:domain sop:SopItem ;
                  rdfs:range xsd:int .


###  http://iff.edu.br/saeg/sopontology#image
sop:image rdf:type owl:DatatypeProperty ;
          rdfs:domain sop:Entity ;
          rdfs:range xsd:string .


###  http://iff.edu.br/saeg/sopontology#name
sop:name rdf:type owl:DatatypeProperty ;
         rdfs:domain sop:Entity ;
         rdfs:range xsd:string .


###  http://iff.edu.br/saeg/sopontology#number
sop:number rdf:type owl:DatatypeProperty ;
           rdfs:domain sop:Sop ;
           rdfs:range xsd:int .


###  http://iff.edu.br/saeg/sopontology#revisionDate
sop:revisionDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain sop:Sop ;
                 rdfs:range xsd:date .


###  http://iff.edu.br/saeg/sopontology#validity
sop:validity rdf:type owl:DatatypeProperty ;
             rdfs:domain sop:Sop ;
             rdfs:range xsd:date .


###  http://iff.edu.br/saeg/sopontology#version
sop:version rdf:type owl:DatatypeProperty ;
            rdfs:domain sop:Sop ;
            rdfs:range xsd:string .


###  http://iff.edu.br/saeg/sopontology#video
sop:video rdf:type owl:DatatypeProperty ;
          rdfs:domain sop:Entity ;
          rdfs:range xsd:string .


###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdfs:domain sop:Sop ;
                    rdfs:range xsd:date .


#################################################################
#    Classes
#################################################################

###  http://iff.edu.br/saeg/sopontology#Activity
sop:Activity rdf:type owl:Class ;
             rdfs:subClassOf sop:Entity ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty sop:performedAt ;
                               owl:someValuesFrom owl:Thing
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty sop:performedBy ;
                               owl:someValuesFrom owl:Thing
                             ] ;
                  rdfs:label "Entity"@en ;
                  rdfs:label "Entidade"@pt ;
                  rdfs:comment "Generic superclass that aggregates common descriptive properties shared by all entities in the ontology, such as name, description, and multimedia references."@en ;
                  rdfs:comment "Superclasse genérica que agrega propriedades descritivas comuns a todas as entidades da ontologia, como nome, descrição e referências multimídia."@pt .


###  http://iff.edu.br/saeg/sopontology#BibliographicReferences
sop:BibliographicReferences rdf:type owl:Class ;
                            rdfs:subClassOf sop:SopItem ;
                            rdfs:label "Bibliographic Reference"@en ;
                            rdfs:label "Referência Bibliográfica"@pt ;
                            rdfs:comment "Represents bibliographic or normative references that support or regulate a Standard Operating Procedure."@en ;
                            rdfs:comment "Representa referências bibliográficas ou normativas que fundamentam ou regulam um Procedimento Operacional Padrão."@pt .



###  http://iff.edu.br/saeg/sopontology#BooleanExpression
sop:BooleanExpression rdf:type owl:Class ;
                      rdfs:subClassOf sop:Entity ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty [ owl:inverseOf sop:guardCondition
                                                       ] ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty [ owl:inverseOf sop:posCondition
                                                       ] ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty [ owl:inverseOf sop:preCondition
                                                       ] ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty sop:name ;
                                        owl:cardinality "1"^^xsd:nonNegativeInteger
                                      ] ;
                                      rdfs:label "Boolean Expression"@en ;
                                      rdfs:label "Expressão Booleana"@pt ;
                                      rdfs:comment "Represents a logical expression used to define preconditions, postconditions, or guard conditions controlling the execution flow of activities and transitions."@en ;
                                      rdfs:comment "Representa uma expressão lógica utilizada para definir pré-condições, pós-condições ou condições de guarda que controlam o fluxo de execução de atividades e transições."@pt .



###  http://iff.edu.br/saeg/sopontology#Document
sop:Document rdf:type owl:Class ;
             rdfs:subClassOf sop:SopItem ;
            rdfs:label "Document"@en ;
            rdfs:label "Documento"@pt ;
            rdfs:comment "Represents auxiliary documents associated with a Standard Operating Procedure, such as forms, records, or attachments."@en ;
            rdfs:comment "Representa documentos auxiliares associados a um Procedimento Operacional Padrão, como formulários, registros ou anexos."@pt .



###  http://iff.edu.br/saeg/sopontology#Entity
sop:Entity rdf:type owl:Class ;
            rdfs:label "Entity"@en ;
            rdfs:label "Entidade"@pt ;
            rdfs:comment "Generic superclass that aggregates common descriptive properties shared by all entities in the ontology, such as name, description, and multimedia references."@en ;
            rdfs:comment "Superclasse genérica que agrega propriedades descritivas comuns a todas as entidades da ontologia, como nome, descrição e referências multimídia."@pt .



###  http://iff.edu.br/saeg/sopontology#Material
sop:Material rdf:type owl:Class ;
             rdfs:subClassOf sop:SopItem ;
        rdfs:label "Material"@en ;
        rdfs:label "Material"@pt ;
        rdfs:comment "Represents materials or resources required to perform activities or steps within a procedure."@en ;
        rdfs:comment "Representa materiais ou recursos necessários para a execução de atividades ou etapas dentro de um procedimento."@pt .



###  http://iff.edu.br/saeg/sopontology#Note
sop:Note rdf:type owl:Class ;
         rdfs:subClassOf sop:SopItem ;
         rdfs:label "Note"@en ;
        rdfs:label "Nota"@pt ;
        rdfs:comment "Represents additional observations or annotations associated with a procedure or its steps."@en ;
        rdfs:comment "Representa observações ou anotações adicionais associadas a um procedimento ou às suas etapas."@pt .



###  http://iff.edu.br/saeg/sopontology#Objective
sop:Objective rdf:type owl:Class ;
              rdfs:subClassOf sop:SopItem ;
              rdfs:label "Objective"@en ;
              rdfs:label "Objetivo"@pt ;
              rdfs:comment "Represents the intended goal or purpose of a Standard Operating Procedure."@en ;
              rdfs:comment "Representa o objetivo ou finalidade pretendida de um Procedimento Operacional Padrão."@pt .



###  http://iff.edu.br/saeg/sopontology#OrganizationPerformer
sop:OrganizationPerformer rdf:type owl:Class ;
                          rdfs:subClassOf sop:Performer ,
                                          org:Organization ;
                                          rdfs:label "Organization-based Performer"@en ;
                          rdfs:label "Executor por Organização"@pt ;
                          rdfs:comment "Represents a performer defined as an organization responsible for executing activities within a procedure."@en ;
                          rdfs:comment "Representa um executor definido como uma organização responsável pela execução de atividades dentro de um procedimento."@pt .



###  http://iff.edu.br/saeg/sopontology#OrganizationPlace
sop:OrganizationPlace rdf:type owl:Class ;
                      rdfs:subClassOf sop:Place ,
                                      org:Organization ;
                      rdfs:label "Organization Place"@en ;
                      rdfs:label "Local Organizacional"@pt ;
                      rdfs:comment "Represents a place associated with an organizational unit where a procedure is executed."@en ;
                      rdfs:comment "Representa um local associado a uma unidade organizacional onde um procedimento é executado."@pt .



###  http://iff.edu.br/saeg/sopontology#Performer
sop:Performer rdf:type owl:Class ;
              rdfs:subClassOf sop:Entity ;
              rdfs:comment "Represents a performer defined by an organizational role rather than an individual or organization"@en ;
              rdfs:label "Performer"@en ;
              rdfs:label "Executor"@pt ;
              rdfs:comment "Represents an agent responsible for performing an activity or step within a procedure."@en ;
              rdfs:comment "Representa o agente responsável pela execução de uma atividade ou etapa dentro de um procedimento."@pt .

              


###  http://iff.edu.br/saeg/sopontology#Place
sop:Place rdf:type owl:Class ;
          rdfs:subClassOf sop:Entity ;
          rdfs:label "Place"@en ;
          rdfs:label "Local"@pt ;
          rdfs:comment "Represents a location where an activity or step of a procedure is performed."@en ;
          rdfs:comment "Representa o local onde uma atividade ou etapa de um procedimento é executada."@pt .



###  http://iff.edu.br/saeg/sopontology#RolePerformer
sop:RolePerformer rdf:type owl:Class ;
                  rdfs:subClassOf sop:Performer ,
                                  org:Role ;
                                  rdfs:label "Role-based Performer"@en ;
                  rdfs:label "Executor por Papel"@pt ;
                  rdfs:comment "Represents a performer defined by an organizational role rather than an individual or organization."@en ;
                  rdfs:comment "Representa um executor definido por um papel organizacional, e não por um indivíduo ou organização específica."@pt .



###  http://iff.edu.br/saeg/sopontology#SafeInstruction
sop:SafeInstruction rdf:type owl:Class ;
                    rdfs:subClassOf sop:SopItem ;
                    rdfs:label "Safety Instruction"@en ;
                    rdfs:label "Instrução de Segurança"@pt ;
                    rdfs:comment "Represents safety-related instructions aimed at preventing risks during the execution of a procedure."@en ;
                    rdfs:comment "Representa instruções relacionadas à segurança, destinadas à prevenção de riscos durante a execução de um procedimento."@pt .



###  http://iff.edu.br/saeg/sopontology#Scope
sop:Scope rdf:type owl:Class ;
          rdfs:subClassOf sop:SopItem ;
          rdfs:label "Scope"@en ;
          rdfs:label "Escopo"@pt ;
          rdfs:comment "Defines the scope of application of a Standard Operating Procedure."@en ;
          rdfs:comment "Define o escopo de aplicação de um Procedimento Operacional Padrão."@pt .



###  http://iff.edu.br/saeg/sopontology#SitePlace
sop:SitePlace rdf:type owl:Class ;
              rdfs:subClassOf sop:Place ,
                              org:Site ;
                              rdfs:label "Site Place"@en ;
              rdfs:label "Local Físico"@pt ;
              rdfs:comment "Represents a physical site where activities of a procedure are carried out."@en ;
              rdfs:comment "Representa um local físico onde as atividades de um procedimento são realizadas."@pt .




###  http://iff.edu.br/saeg/sopontology#Sop
sop:Sop rdf:type owl:Class ;
        rdfs:subClassOf sop:Activity ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:status ;
                          owl:someValuesFrom owl:Thing
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty [ owl:inverseOf sop:previousVersion
                                         ] ;
                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:name ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:number ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:validity ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:version ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:approvalDate ;
                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:creationDate ;
                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty sop:revisionDate ;
                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                        ] ;
          rdfs:label "Standard Operating Procedure"@en ;
          rdfs:label "Procedimento Operacional Padrão"@pt ;
          rdfs:comment "Represents a Standard Operating Procedure as a normative document that formally describes an operational process, including its versioning, lifecycle, and responsibilities."@en ;
          rdfs:comment "Representa um Procedimento Operacional Padrão como um documento normativo que descreve formalmente um processo operacional, incluindo versionamento, ciclo de vida e responsabilidades."@pt .



###  http://iff.edu.br/saeg/sopontology#SopItem
sop:SopItem rdf:type owl:Class ;
            rdfs:subClassOf sop:Entity ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty [ owl:inverseOf sop:sopItem
                                             ] ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty sop:discriminator ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty sop:name ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ;
            rdfs:label "SOP Item"@en ;
            rdfs:label "Item do POP"@pt ;
            rdfs:comment "Abstract class representing complementary informational or documentary elements associated with a Standard Operating Procedure."@en ;
            rdfs:comment "Classe abstrata que representa elementos informacionais ou documentais complementares associados a um Procedimento Operacional Padrão."@pt .



###  http://iff.edu.br/saeg/sopontology#SopStatus
sop:SopStatus rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( sop:approved
                                                sop:draft
                                                sop:obsolete
                                                sop:published
                                                sop:retired
                                              )
                                  ] ;
              rdfs:subClassOf sop:Entity ;
              rdfs:label "SOP Status"@en ;
              rdfs:label "Status do POP"@pt ;
              rdfs:comment "Represents the lifecycle status of a Standard Operating Procedure, such as draft, approved, revised, or obsolete."@en ;
              rdfs:comment "Representa o estado do ciclo de vida de um Procedimento Operacional Padrão, como rascunho, aprovado, revisado ou obsoleto."@pt .



###  http://iff.edu.br/saeg/sopontology#Step
sop:Step rdf:type owl:Class ;
         rdfs:subClassOf sop:Activity ,
                         sop:SopItem ;
          rdfs:label "Step"@en ;
          rdfs:label "Etapa"@pt ;
          rdfs:comment "Represents a concrete execution instance of an activity within the context of a specific Standard Operating Procedure."@en ;
          rdfs:comment "Representa a instância concreta de execução de uma atividade no contexto de um Procedimento Operacional Padrão específico."@pt .



###  http://iff.edu.br/saeg/sopontology#Transition
sop:Transition rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty sop:target ;
                                 owl:someValuesFrom sop:Step
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty [ owl:inverseOf sop:transition
                                                ] ;
                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                               ] ;
                               rdfs:label "Transition"@en ;
                rdfs:label "Transição"@pt ;
                rdfs:comment "Represents a directed transition between activities, defining the possible flow of execution within a procedure."@en ;
                rdfs:comment "Representa uma transição direcionada entre atividades, definindo o fluxo possível de execução dentro de um procedimento."@pt .



###  http://iff.edu.br/saeg/sopontology#UsageFrequency
sop:UsageFrequency rdf:type owl:Class ;
                   rdfs:subClassOf sop:SopItem ;
                   rdfs:label "Usage Frequency"@en ;
                  rdfs:label "Frequência de Uso"@pt ;
                  rdfs:comment "Represents the frequency with which a Standard Operating Procedure is expected to be executed, such as daily, weekly, monthly, or on demand."@en ;
                  rdfs:comment "Representa a frequência com que um Procedimento Operacional Padrão deve ser executado, como diária, semanal, mensal ou sob demanda."@pt .



###  http://iff.edu.br/saeg/sopontology#UsageSituation
sop:UsageSituation rdf:type owl:Class ;
                   rdfs:subClassOf sop:SopItem ;
                   rdfs:label "Usage Situation"@en ;
                    rdfs:label "Situação de Uso"@pt ;
                    rdfs:comment "Represents situations or contexts in which a Standard Operating Procedure should be applied."@en ;
                    rdfs:comment "Representa situações ou contextos nos quais um Procedimento Operacional Padrão deve ser aplicado."@pt .



#################################################################
#    Individuals
#################################################################

###  http://iff.edu.br/saeg/sopontology#approved
sop:approved rdf:type owl:NamedIndividual .


###  http://iff.edu.br/saeg/sopontology#draft
sop:draft rdf:type owl:NamedIndividual .


###  http://iff.edu.br/saeg/sopontology#obsolete
sop:obsolete rdf:type owl:NamedIndividual .


###  http://iff.edu.br/saeg/sopontology#published
sop:published rdf:type owl:NamedIndividual .


###  http://iff.edu.br/saeg/sopontology#retired
sop:retired rdf:type owl:NamedIndividual .


